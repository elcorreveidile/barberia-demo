# === Base de datos (Neon Postgres) ===
# Cadena de conexión de Neon. Usa la "Pooled connection" para serverless.
DATABASE_URL="postgresql://usuario:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# === Email (Resend) — magic link y confirmaciones ===
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Filo Barber Studio <reservas@tudominio.com>"

# === Autenticación del panel ===
# Secreto para firmar las cookies de sesión y los magic links. Genera uno con:
#   openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# Email(es) autorizados a entrar al panel, separados por coma.
ADMIN_EMAILS="javier@blablaele.com"

# === IA conversacional (Anthropic / Claude) ===
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxx"

# === WhatsApp (Twilio sandbox para la demo) ===
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Número del sandbox de WhatsApp de Twilio (formato whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# === URL pública del sitio (para enlaces en emails) ===
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === (Opcional) Producción con Meta WhatsApp Cloud API ===
# Token para verificar el webhook (GET hub.challenge) al pasar a Meta.
WHATSAPP_VERIFY_TOKEN="un-token-de-verificacion-a-tu-eleccion"
